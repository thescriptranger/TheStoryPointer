{
  "name": "the-story-pointer",
  "version": "1.0.0",
  "private": true,
  "description": "Anonymous story-point estimation for Scrum teams.",
  "type": "module",
  "scripts": {
    "build:client": "esbuild src/client/landing.ts src/client/room.ts --bundle --outdir=public/js --format=esm --target=es2020 --sourcemap",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "dev": "npm run build:client && tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.20.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
