{
  "name": "the-story-pointer",
  "version": "2.0.0",
  "private": true,
  "description": "Anonymous story-point estimation for Scrum teams, deployable to Vercel.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/client/landing.ts src/client/room.ts src/client/circuit-bg.ts --bundle --outdir=public/js --format=esm --target=es2020 --minify",
    "dev:client": "esbuild src/client/landing.ts src/client/room.ts src/client/circuit-bg.ts --bundle --outdir=public/js --format=esm --target=es2020 --sourcemap",
    "dev": "npm run dev:client && tsx watch server-local.ts",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.client.json"
  },
  "dependencies": {
    "@upstash/redis": "^1.28.4",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@vercel/node": "^3.2.0",
    "esbuild": "^0.20.2",
    "express": "^4.19.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
